BASE_URL=value
NOTION_ACCESS_TOKEN=value
NOTION_DATABASE_GEARS_ID=value
NOTION_DATABASE_CONTENT_ID=value
NOTION_PAGE_HOME_ID=value
NOTION_PAGE_ABOUT_ID=value
NOTION_PAGE_WORK_ID=value
NOTION_PAGE_BLOG_ID=value
NOTION_PAGE_GEARS_ID=value
REVALIDATION_SECRET=value
# Optional: rich_text property name on the content DB (exact URL slug per row). When set, slug lookups use one filtered query instead of scanning pages.
# NOTION_SLUG_PROPERTY=Slug

# Supabase (nublson project) — used server-side only for the reactions system
# Get the service role key from https://supabase.com/dashboard/project/ubwmngcqwvdvcyprcdmf/settings/api
NEXT_PUBLIC_SUPABASE_URL=value
SUPABASE_SERVICE_ROLE_KEY=value
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=value

# Fingerprint Pro — cross-browser device identification for reaction dedup
# Get your public API key from https://dashboard.fingerprint.com
NEXT_PUBLIC_FINGERPRINT_API_KEY=value
