BASE_URL=value
NOTION_ACCESS_TOKEN=value
NOTION_DATABASE_GEARS_ID=value
NOTION_DATABASE_CONTENT_ID=value
NOTION_PAGE_HOME_ID=value
NOTION_PAGE_ABOUT_ID=value
NOTION_PAGE_WORK_ID=value
